pragma language_version >= 0.16.0;
import CompactStandardLibrary;

export ledger tag_cell: Bytes<32>;
export ledger scratch: Field;

export struct Point {
  x: Uint<32>,
  flag: Boolean,
  label: Bytes<32>,
}

// A struct flowing straight into persistentHash / persistentCommit.
export circuit hash_struct(p: Point): Bytes<32> {
  const h = persistentHash<Point>(p);
  const c = persistentCommit<Point>(p, h);
  tag_cell = disclose(c);
  return c;
}

// Same struct into the transient (Poseidon) side.
export circuit commit_struct(p: Point, r: Field): Field {
  const c = transientCommit<Point>(p, r);
  scratch = disclose(c);
  return c;
}
