// Shared type and ledger declarations for the gateway contract.
//
// gateway.compact includes this file to reuse these definitions.
// gateway-core.compact is also compiled standalone for the lazy deployment
// pattern: deploy this first (no circuits), then add circuits from the
// full contract via submitInsertVerifierKeyTx.
//
// The compiler assigns each ledger field a positional index (0, 1, 2, ...)
// based on declaration order, and every circuit's ZKIR references fields
// by that index. Because gateway.compact includes this file, the layouts
// are guaranteed identical.

pragma language_version >= 0.22.0;

import CompactStandardLibrary;

// CAIP-2 blockchain identifier (max 41 bytes)
// Ref: https://github.com/ChainAgnostic/CAIPs/blob/main/CAIPs/caip-2.md
type ChainId = Bytes<41>;

struct UnclaimedDeposit {
  amount: Uint<128>,
  token_ref: Bytes<32>,
}

enum JobStatus { pending, completed }

struct EgressJob {
  id: Uint<128>,
  destination: Bytes<32>,
  token_ref: Bytes<32>,
  amount: Uint<128>,
  status: JobStatus,
}

// Cross-chain signing request (ADR-014)
enum SigningRequestStatus { pending, fulfilled }

// Preimage for entity_id: H(address_kind || address || salt)
// address_kind: 0x00 = ZswapCoinPublicKey (0x01, 0x02 reserved)
struct EntityIdPreimage {
  address_kind: Uint<8>,
  address: Bytes<32>,
  salt: Bytes<32>,
}

struct SigningRequest {
  entity_id: Bytes<32>,
  domain_id: Uint<8>,
  payload: Bytes<32>,
  status: SigningRequestStatus,
  signature: Bytes<64>,
}

export ledger threshold: Uint<8>;
export ledger validators: Set<JubjubPoint>;
export ledger unclaimed_deposits: Map<Bytes<32>, UnclaimedDeposit>;
export ledger next_job_id: Counter;
export ledger egress_jobs: Map<Field, EgressJob>;
export ledger processed_attestations: Set<Bytes<32>>;
// Cross-chain signing (ADR-014)
export ledger signing_fee: Uint<64>;
export ledger fee_token: Bytes<32>;
export ledger next_signing_request_id: Counter;
export ledger signing_requests: Map<Field, SigningRequest>;

// State used to generate new nonces every time a token is minted.
export ledger mint_counter: Counter;

// Constructor parameters:
//
// * `initial_validators` — up to 9 validator public keys to seed the
//   `validators` set at deployment time. Slots set to `Maybe::None` are
//   skipped. The set is empty by default; the deployer is responsible for
//   passing the engine's keystore validators here so that subsequent
//   `witness_deposit` calls can have their signatures verified.
// * `initial_threshold` — minimum number of valid signatures required by
//   `verify_threshold_sigs`. Pass `0` for an open gateway, or any value
//   `<=` the number of seeded validators for a real threshold check.
//
// TODO: Remove the egress-jobs seed before production. It's currently
// here so integration tests can verify the full read/deserialize path
// without a callable circuit.
constructor(
  initial_validators: Vector<9, Maybe<JubjubPoint>>,
  initial_threshold: Uint<8>,
  initial_fee_token: Bytes<32>,
  initial_signing_fee: Uint<64>
) {
  // Constructor params are private witnesses by default; all fields are
  // public deployment-time configuration so we disclose them up front.
  const disclosed_validators = disclose(initial_validators);
  threshold = disclose(initial_threshold);
  fee_token = disclose(initial_fee_token);
  signing_fee = disclose(initial_signing_fee);
  for (const i of 0..9) {
    if (disclosed_validators[i].is_some) {
      validators.insert(disclosed_validators[i].value);
    }
  }

  egress_jobs.insert(next_job_id as Field, EgressJob {
    id: next_job_id as Uint<128>,
    destination: pad(32, "test-destination"),
    token_ref: pad(32, "BTC"),
    amount: 1000 as Uint<128>,
    status: JobStatus.pending,
  });
  next_job_id.increment(1);
}
