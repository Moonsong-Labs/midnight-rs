include "gateway-core";

type Salt = Bytes<32>;

// Jubjub signature: validator provides their public key alongside (r, s)
struct ValidatorSignature {
  pk: JubjubPoint,
  r: JubjubPoint,
  s: Field,
}

// Attestation domain separation
enum AttestationKind { deposit, egress, signing }

struct DepositAttestation {
  kind: AttestationKind,
  channel_id: Bytes<32>,
  amount: Uint<128>,
  token_ref: Bytes<32>,
}

struct EgressAttestation {
  kind: AttestationKind,
  job_id: Uint<128>,
}

struct SigningAttestation {
  kind: AttestationKind,
  request_id: Uint<128>,
  signature: Bytes<64>,
}

// --- Token & chain constants (zero-arg pure circuits act as named constants) ---

// Supported tokens
pure circuit TOKEN_BTC(): Bytes<32> { return pad(32, "BTC"); }
pure circuit TOKEN_ETH(): Bytes<32> { return pad(32, "ETH"); }
pure circuit TOKEN_ADA(): Bytes<32> { return pad(32, "ADA"); }

// CAIP-2 chain IDs (token_ref → chain is 1:1)
pure circuit CHAIN_BTC(): ChainId { return pad(41, "bip122:000000000019d6689c085ae165831e93"); }
pure circuit CHAIN_ETH(): ChainId { return pad(41, "eip155:1"); }
pure circuit CHAIN_ADA(): ChainId { return pad(41, "cardano:mainnet"); }

// --- Helpers ---

// Token-to-chain mapping (1:1). Asserts token is supported, returns its CAIP-2 chain.
circuit token_to_chain(token_ref: Bytes<32>): ChainId {
  const is_btc = token_ref == TOKEN_BTC();
  const is_eth = token_ref == TOKEN_ETH();
  const is_ada = token_ref == TOKEN_ADA();
  assert(is_btc || is_eth || is_ada, "Unsupported token");
  return is_btc ? CHAIN_BTC() : is_eth ? CHAIN_ETH() : CHAIN_ADA();
}

// Verify a Jubjub signature: s·G == R + H(R‖pk‖m)·pk
circuit verify_jubjub_sig(pk: JubjubPoint, r: JubjubPoint, s: Field, message_hash: Bytes<32>): Boolean {
  const challenge = transientHash<Vector<5, Field>>([jubjubPointX(r), jubjubPointY(r), jubjubPointX(pk), jubjubPointY(pk), degradeToTransient(message_hash)]);
  const lhs = ecMulGenerator(s);
  const rhs = ecAdd(r, ecMul(pk, challenge));
  return jubjubPointX(lhs) == jubjubPointX(rhs) && jubjubPointY(lhs) == jubjubPointY(rhs);
}

// Count a single optional signature slot: returns 1 if present, registered, and valid; 0 otherwise
circuit count_valid_sig(sig: Maybe<ValidatorSignature>, message_hash: Bytes<32>): Uint<8> {
  return (sig.is_some && validators.member(sig.value.pk) && verify_jubjub_sig(sig.value.pk, sig.value.r, sig.value.s, message_hash))
    ? 1 as Uint<8> : 0 as Uint<8>;
}

// Verify at least `threshold` signatures from distinct registered validators
circuit verify_threshold_sigs(sigs: Vector<9, Maybe<ValidatorSignature>>, message_hash: Bytes<32>): [] {
  const flags = map((sig) => count_valid_sig(sig, message_hash), sigs);
  const valid_count = fold((count, flag) => (count + flag) as Uint<8>, 0 as Uint<8>, flags);
  assert(valid_count >= threshold, "Insufficient valid signatures");

  // Pairwise distinctness: no two present signatures may share a public key.
  // When either slot is none, (is_some && is_some) is false so the assert trivially passes.
  for (const i of 0..9) {
    for (const j of 0..9) {
      assert(i >= j || !(sigs[i].is_some && sigs[j].is_some)
        || jubjubPointX(sigs[i].value.pk) != jubjubPointX(sigs[j].value.pk)
        || jubjubPointY(sigs[i].value.pk) != jubjubPointY(sigs[j].value.pk), "Duplicate signer");
    }
  }
}

// --- Circuits ---

export circuit claim_deposit(salt: Salt): [] {
  const pk = ownPublicKey();
  const channel_id = disclose(persistentHash<Vector<2, Bytes<32>>>([pk.bytes, salt]));
  assert(unclaimed_deposits.member(channel_id), "No unclaimed deposit");
  const deposit = unclaimed_deposits.lookup(channel_id);
  // deposit.amount is bounded to Uint<64> max by witness_deposit
  const nonce = evolveNonce(mint_counter, deposit.token_ref);
  mintShieldedToken(deposit.token_ref, deposit.amount as Uint<64>, nonce, left<ZswapCoinPublicKey, ContractAddress>(pk));
  mint_counter.increment(1);
  unclaimed_deposits.remove(channel_id);
}

export circuit witness_deposit(
  sigs: Vector<9, Maybe<ValidatorSignature>>,
  channel_id: Bytes<32>,
  amount: Uint<128>,
  token_ref: Bytes<32>
): [] {
  const channel_id_val = disclose(channel_id);
  const amount_val = disclose(amount);
  const token_ref_val = disclose(token_ref);

  token_to_chain(token_ref_val);
  assert(amount_val <= 0xFFFFFFFFFFFFFFFF as Uint<128>, "Amount exceeds Uint<64> max");

  const attestation_hash = persistentHash<DepositAttestation>(DepositAttestation {
    kind: AttestationKind.deposit,
    channel_id: channel_id_val,
    amount: amount_val,
    token_ref: token_ref_val,
  });
  assert(!processed_attestations.member(attestation_hash), "Attestation already processed");

  // TODO(signatures): disabled for witness_deposit until the orchestrator
  // collects Jubjub sigs from all validators (currently only the leader signs).
  // verify_threshold_sigs(disclose(sigs), attestation_hash);

  assert(!unclaimed_deposits.member(channel_id_val), "Channel already has an unclaimed deposit");
  unclaimed_deposits.insert(channel_id_val, UnclaimedDeposit { amount: amount_val, token_ref: token_ref_val });

  processed_attestations.insert(attestation_hash);
}

export circuit witness_egress(
  sigs: Vector<9, Maybe<ValidatorSignature>>,
  job_id: Uint<128>
): [] {
  const job_id_val = disclose(job_id);
  const attestation_hash = persistentHash<EgressAttestation>(EgressAttestation {
    kind: AttestationKind.egress,
    job_id: job_id_val,
  });
  assert(!processed_attestations.member(attestation_hash), "Attestation already processed");

  // TODO(signatures): see witness_deposit above — temporarily disabled.
  // verify_threshold_sigs(disclose(sigs), attestation_hash);

  const job_key = job_id_val as Field;
  assert(egress_jobs.member(job_key), "Egress job not found");
  const job = egress_jobs.lookup(job_key);
  assert(job.status == JobStatus.pending, "Job not pending");

  egress_jobs.insert(job_key, EgressJob {
    id: job.id, destination: job.destination, token_ref: job.token_ref,
    amount: job.amount, status: JobStatus.completed,
  });

  processed_attestations.insert(attestation_hash);
}

export circuit withdraw(
  coin: ShieldedCoinInfo,
  destination: Bytes<32>
): Uint<128> {
  const disclosed_coin = disclose(coin);
  const disclosed_dest = disclose(destination);

  assert(disclosed_coin.value > 0 as Uint<64>, "Withdrawal amount must be positive");
  token_to_chain(disclosed_coin.color);

  receiveShielded(disclosed_coin);

  const job_id_val = next_job_id as Uint<128>;
  egress_jobs.insert(job_id_val as Field, EgressJob {
    id: job_id_val, destination: disclosed_dest, token_ref: disclosed_coin.color,
    amount: disclosed_coin.value as Uint<128>, status: JobStatus.pending,
  });
  next_job_id.increment(1);
  return job_id_val;
}

// --- Cross-chain signing (ADR-014) ---

// Domain ID validation: 0 = FROST secp256k1 (Bitcoin), 1 = FROST Ed25519 (Cardano), 2 = ECDSA secp256k1 (EVM)
circuit validate_domain_id(domain_id: Uint<8>): [] {
  assert(domain_id == (0 as Uint<8>) || domain_id == (1 as Uint<8>) || domain_id == (2 as Uint<8>), "Invalid domain_id");
}

// Request a cross-chain signature from MCS validators.
// The caller proves ownership of their ZswapCoinPublicKey via ownPublicKey().
// entity_id = H(address_kind || address || salt) is computed inside the ZK circuit,
// hiding the caller's identity from validators and on-chain observers.
// Validators compute tweak = H("mcs-derivation" || domain_id || entity_id) off-chain
// and sign with the derived key: derived_pubkey = master_pubkey + tweak * G.
export circuit sign(
  payload: Bytes<32>,
  domain_id: Uint<8>,
  salt: Salt,
  fee_coin: ShieldedCoinInfo
): Uint<128> {
  const disclosed_domain_id = disclose(domain_id);
  const disclosed_payload = disclose(payload);
  validate_domain_id(disclosed_domain_id);

  // Prove identity ownership and compute entity_id inside ZK circuit.
  // Only entity_id is disclosed; address_kind, pk, and salt remain private.
  const pk = ownPublicKey();
  const entity_id = persistentHash<EntityIdPreimage>(EntityIdPreimage {
    address_kind: 0 as Uint<8>,
    address: pk.bytes,
    salt: salt,
  });
  const disclosed_entity_id = disclose(entity_id);

  // Fee handling: caller deposits a shielded coin to prevent spam.
  const disclosed_fee = disclose(fee_coin);
  assert(disclosed_fee.color == fee_token, "Invalid fee token");
  assert(disclosed_fee.value >= signing_fee, "Insufficient fee");
  // TODO(fee-gate): temporarily disabled because `receiveShielded`
  // requires the caller's wallet to hold a real unspent shielded coin
  // matching `fee_token`, and the genesis mint wallet only gets
  // unshielded NIGHT. Re-enable once we have a pre-funding path (e.g.
  // mint a shielded test-token coin into the wallet before
  // `enqueue-sign`, or switch the fee mechanism to the unshielded
  // DUST abstraction).
  // receiveShielded(disclosed_fee);

  // Create signing request (emitted as public ledger state for validators to index)
  const request_id = next_signing_request_id as Uint<128>;
  signing_requests.insert(request_id as Field, SigningRequest {
    entity_id: disclosed_entity_id,
    domain_id: disclosed_domain_id,
    payload: disclosed_payload,
    status: SigningRequestStatus.pending,
    signature: pad(64, ""),
  });
  next_signing_request_id.increment(1);
  return request_id;
}

// Validators submit the aggregated cross-chain signature for a pending signing request.
// Requires threshold attestation (6-of-9 Jubjub Schnorr) to prove validator consensus.
export circuit fulfill_signing_request(
  sigs: Vector<9, Maybe<ValidatorSignature>>,
  request_id: Uint<128>,
  signature: Bytes<64>
): [] {
  const request_id_val = disclose(request_id);
  const signature_val = disclose(signature);

  const request_key = request_id_val as Field;
  assert(signing_requests.member(request_key), "Signing request not found");
  const request = signing_requests.lookup(request_key);
  assert(request.status == SigningRequestStatus.pending, "Request not pending");

  // Replay protection: hash the attestation including the signature payload
  const attestation_hash = persistentHash<SigningAttestation>(SigningAttestation {
    kind: AttestationKind.signing,
    request_id: request_id_val,
    signature: signature_val,
  });
  assert(!processed_attestations.member(attestation_hash), "Attestation already processed");

  verify_threshold_sigs(disclose(sigs), attestation_hash);

  // Fulfill the request with the aggregated cross-chain signature
  signing_requests.insert(request_key, SigningRequest {
    entity_id: request.entity_id,
    domain_id: request.domain_id,
    payload: request.payload,
    status: SigningRequestStatus.fulfilled,
    signature: signature_val,
  });

  processed_attestations.insert(attestation_hash);
}
